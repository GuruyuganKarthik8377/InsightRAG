# ==============================================================================
# InsightRAG - Environment Variables Template
# ==============================================================================
# Copy this file to `backend/.env` and fill in your actual credentials.
# Do NOT commit your actual `.env` file containing secrets to version control!
# ==============================================================================

# --- LLM API Configuration ---
# Your Anthropic Claude API Key (Required for Layer-3 synthesis)
# Obtain a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=YOUR_API_KEY_HERE

# The Claude model to use for grounded answer generation
# Options: claude-sonnet-4-5-20250929, claude-3-5-sonnet-20241022, etc.
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# --- Embedding & Retrieval Models ---
# The local dense embedding model loaded via SentenceTransformers
EMBED_MODEL=BAAI/bge-large-en

# The local cross-encoder model loaded via SentenceTransformers for reranking
RERANK_MODEL=BAAI/bge-reranker-large

# --- Local Directory Paths (Storage) ---
# Path where FAISS vector index will be saved
FAISS_INDEX_PATH=data/faiss_index/index.faiss

# Path where document chunk metadata pickle file will be saved
METADATA_PATH=data/faiss_index/metadata.pkl

# Temporary upload folder for processing raw documents
UPLOAD_DIR=data/raw_docs
